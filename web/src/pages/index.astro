---
import Layout from '../layouts/Layout.astro';
import { THEMES } from '../lib/themes';

const themeEntries = Object.entries(THEMES);
---

<Layout title="claudeline — Status Line Preview">
  <div class="app">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="brand">
          <div class="brand-icon"><i data-lucide="terminal"></i></div>
          <div>
            <div class="brand-name">claudeline</div>
            <div class="brand-sub">Status Line Builder</div>
          </div>
        </div>
      </div>
      <div class="sidebar-scroll" id="segment-categories">
        <!-- built by JS -->
      </div>
    </aside>

    <!-- Main -->
    <main>
      <div class="page-header anim" style="--i:0">
        <p class="page-desc">Configure and preview your Claude Code status line</p>
      </div>

      <!-- Theme selector -->
      <section class="anim" style="--i:1">
        <div class="theme-row">
          <label for="theme-select"><i data-lucide="palette"></i> Theme</label>
          <select id="theme-select">
            {themeEntries.map(([name]) => (
              <option value={name} selected={name === 'default'}>{name}</option>
            ))}
            <option value="__custom">Custom</option>
          </select>
        </div>
      </section>

      <!-- Chip builder -->
      <section class="anim" style="--i:1">
        <div class="section-label"><i data-lucide="layers"></i> Format</div>
        <div class="chip-builder" id="chip-builder">
          <div class="builder-empty" id="builder-empty">
            <i data-lucide="plus-circle"></i>
            <span>Drag or click segments from the sidebar</span>
          </div>
        </div>
      </section>

      <!-- Terminal Preview -->
      <section class="anim" style="--i:2">
        <div class="section-label"><i data-lucide="monitor"></i> Preview</div>
        <div class="terminal-glow">
          <div class="terminal">
            <div class="terminal-chrome">
              <div class="terminal-dots"><span></span><span></span><span></span></div>
              <div class="terminal-title">Claude Code</div>
              <div class="terminal-dots" style="visibility:hidden"><span></span><span></span><span></span></div>
            </div>
            <div class="terminal-body">
              <div class="prompt-line">
                <span class="prompt-char">$</span>
                <span class="cursor"></span>
              </div>
              <div class="statusline" id="statusline-output"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- Install -->
      <section class="anim" style="--i:3">
        <div class="section-label"><i data-lucide="download"></i> Install</div>
        <div class="install-card">
          <code id="install-command">npx claudeline --install --theme default</code>
          <button id="copy-btn" title="Copy to clipboard">
            <span class="copy-default"><i data-lucide="clipboard"></i></span>
            <span class="copy-done"><i data-lucide="clipboard-check"></i></span>
          </button>
        </div>
      </section>
    </main>
  </div>

  <!-- FAB -->
  <button id="fab" title="Mock data settings" aria-label="Mock data settings">
    <i data-lucide="settings"></i>
  </button>

  <!-- Bottom sheet overlay -->
  <div id="sheet-overlay" class="sheet-overlay"></div>

  <!-- Bottom sheet -->
  <div id="sheet" class="sheet">
    <div class="sheet-head">
      <h3><i data-lucide="sliders-horizontal"></i> Mock Data</h3>
      <button id="sheet-close" class="sheet-close" aria-label="Close"><i data-lucide="x"></i></button>
    </div>
    <div class="sheet-body">
      <div class="sheet-row">
        <div class="sheet-field">
          <label for="model-select">Model</label>
          <select id="model-select">
            <option value="Sonnet" data-id="claude-sonnet-4-6">Sonnet</option>
            <option value="Opus" data-id="claude-opus-4-6">Opus</option>
            <option value="Haiku" data-id="claude-haiku-4-5-20251001">Haiku</option>
          </select>
        </div>
        <div class="sheet-field">
          <label for="effort-select">Effort</label>
          <select id="effort-select">
            <option value="high">high</option>
            <option value="medium">medium</option>
            <option value="low">low</option>
          </select>
        </div>
      </div>
      <div class="sheet-row">
        <div class="sheet-field">
          <label for="ctx-slider">Context %</label>
          <div class="slider-row">
            <input type="range" id="ctx-slider" min="0" max="100" value="42" />
            <span id="ctx-value" class="slider-val">42%</span>
          </div>
        </div>
      </div>
      <div class="sheet-row">
        <div class="sheet-field">
          <label for="cost-input">Cost ($)</label>
          <input type="number" id="cost-input" value="0.02" step="0.01" min="0" />
        </div>
        <div class="sheet-field">
          <label for="dir-input">Directory</label>
          <input type="text" id="dir-input" value="myapp" spellcheck="false" />
        </div>
      </div>
      <div class="sheet-row">
        <div class="sheet-field">
          <label for="branch-input">Branch</label>
          <input type="text" id="branch-input" value="main" spellcheck="false" />
        </div>
        <div class="sheet-field">
          <label for="git-status-select">Git status</label>
          <select id="git-status-select">
            <option value="clean">clean</option>
            <option value="dirty">dirty</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- Theme data for client JS -->
  <script id="theme-data" type="application/json" set:html={JSON.stringify(THEMES)} />

  <script>
    import {
      createIcons,
      Sparkles, Gauge, DollarSign, FolderOpen, GitBranch,
      Terminal, Clock, Activity, GripHorizontal, Shapes,
      Clipboard, ClipboardCheck, X, Settings, Download,
      Palette, Monitor, SlidersHorizontal, Plus,
      PlusCircle, Layers,
    } from 'lucide';
    import { renderToHtml } from '../lib/renderer';
    import { MOCK_DATA } from '../lib/mock-data';
    import type { ClaudeInput } from '../lib/types';

    const LUCIDE_ICONS = {
      Sparkles, Gauge, DollarSign, FolderOpen, GitBranch,
      Terminal, Clock, Activity, GripHorizontal, Shapes,
      Clipboard, ClipboardCheck, X, Settings, Download,
      Palette, Monitor, SlidersHorizontal, Plus,
      PlusCircle, Layers,
    };

    const themes: Record<string, string> = JSON.parse(
      document.getElementById('theme-data')!.textContent!
    );

    // --- DOM refs ---
    const themeSelect = document.getElementById('theme-select') as HTMLSelectElement;
    const modelSelect = document.getElementById('model-select') as HTMLSelectElement;
    const effortSelect = document.getElementById('effort-select') as HTMLSelectElement;
    const ctxSlider = document.getElementById('ctx-slider') as HTMLInputElement;
    const ctxValue = document.getElementById('ctx-value') as HTMLSpanElement;
    const costInput = document.getElementById('cost-input') as HTMLInputElement;
    const dirInput = document.getElementById('dir-input') as HTMLInputElement;
    const branchInput = document.getElementById('branch-input') as HTMLInputElement;
    const gitStatusSelect = document.getElementById('git-status-select') as HTMLSelectElement;
    const output = document.getElementById('statusline-output') as HTMLDivElement;
    const installCmd = document.getElementById('install-command') as HTMLElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const segCats = document.getElementById('segment-categories') as HTMLDivElement;
    const builder = document.getElementById('chip-builder') as HTMLDivElement;
    const builderEmpty = document.getElementById('builder-empty') as HTMLDivElement;

    const fab = document.getElementById('fab') as HTMLButtonElement;
    const sheet = document.getElementById('sheet') as HTMLDivElement;
    const sheetOverlay = document.getElementById('sheet-overlay') as HTMLDivElement;
    const sheetClose = document.getElementById('sheet-close') as HTMLButtonElement;

    fab.addEventListener('click', () => { sheet.classList.add('open'); sheetOverlay.classList.add('open'); });
    sheetClose.addEventListener('click', () => { sheet.classList.remove('open'); sheetOverlay.classList.remove('open'); });
    sheetOverlay.addEventListener('click', () => { sheet.classList.remove('open'); sheetOverlay.classList.remove('open'); });

    let mockData: Partial<ClaudeInput> = structuredClone(MOCK_DATA);

    // --- Chip data model ---
    interface Chip { id: string; token: string; }
    let chips: Chip[] = [];
    let chipIdCounter = 0;
    function nextId(): string { return 'c' + (chipIdCounter++); }

    // --- Tokenizer: format string → token list ---
    function tokenize(format: string): string[] {
      const tokens: string[] = [];
      let i = 0;
      const s = format.trim();
      while (i < s.length) {
        while (i < s.length && /\s/.test(s[i])) i++;
        if (i >= s.length) break;

        if ('[({<'.includes(s[i])) {
          const open = s[i];
          const close = open === '[' ? ']' : open === '(' ? ')' : open === '{' ? '}' : '>';
          let depth = 1, j = i + 1;
          while (j < s.length && depth > 0) {
            if (s[j] === open) depth++;
            else if (s[j] === close) depth--;
            j++;
          }
          tokens.push(s.slice(i, j));
          i = j;
          continue;
        }

        if (s.slice(i, i + 3) === 'if:') {
          let j = i + 3;
          while (j < s.length && s[j] !== '(' && !/\s/.test(s[j])) j++;
          if (j < s.length && s[j] === '(') {
            let depth = 1; j++;
            while (j < s.length && depth > 0) {
              if (s[j] === '(') depth++;
              else if (s[j] === ')') depth--;
              j++;
            }
          }
          tokens.push(s.slice(i, j));
          i = j;
          continue;
        }

        let j = i;
        while (j < s.length && !/\s/.test(s[j])) j++;
        const tok = s.slice(i, j);
        if (tok && tok !== ',') tokens.push(tok);
        i = j;
      }
      return tokens;
    }

    // --- Chip display info ---
    const STYLE_SET = new Set(['bold','dim','italic','underline','strikethrough','blink','inverse','hidden','black','red','green','yellow','blue','magenta','cyan','white','gray','grey','bright-red','bright-green','bright-yellow','bright-blue','bright-magenta','bright-cyan','bright-white','bg-black','bg-red','bg-green','bg-yellow','bg-blue','bg-magenta','bg-cyan','bg-white']);

    const TYPE_COLORS: Record<string, string> = {
      claude: '#c084fc', ctx: '#60a5fa', cost: '#4ade80',
      fs: '#fbbf24', git: '#fb923c', env: '#22d3ee',
      time: '#fb7185', usage: '#2dd4bf', sep: '#71717a',
      nerd: '#818cf8', emoji: '#818cf8', text: '#a1a1aa',
      account: '#c084fc',
    };

    const SEP_CHARS: Record<string, string> = {
      pipe: '|', arrow: '→', 'arrow-left': '←', 'arrow-right': '→',
      dot: '•', dash: '–', slash: '/', chevron: '›', middot: '·',
      powerline: '', newline: '↵', colon: ':', space: '⎵',
      none: '∅', 'double-colon': '::', tilde: '~', backslash: '\\',
      'double-pipe': '‖', bullet: '◦', diamond: '◇', star: '★',
      'chevron-left': '‹', 'powerline-left': '', 'powerline-thin': '',
      'powerline-thin-left': '', br: '↵',
    };

    function chipInfo(token: string): { label: string; color: string; typeLabel: string } {
      // Groups — show bracket + abbreviated inner content
      if (token.startsWith('[') || token.startsWith('(') || token.startsWith('{') || token.startsWith('<')) {
        const bracket = token[0];
        const inner = token.slice(1, -1).trim();
        // Try to get a nice label from first inner token
        const firstInner = tokenize(inner);
        if (firstInner.length === 1) {
          const info = chipInfo(firstInner[0]);
          return { label: `${bracket}${info.label}${token.slice(-1)}`, color: info.color, typeLabel: 'group' };
        }
        const preview = firstInner.slice(0, 2).map(t => chipInfo(t).label).join(' ');
        const suffix = firstInner.length > 2 ? ' …' : '';
        return { label: `${bracket}${preview}${suffix}${token.slice(-1)}`, color: '#94a3b8', typeLabel: 'group' };
      }

      // Conditionals — show "if condition …"
      if (token.startsWith('if:')) {
        const cond = token.slice(3).split('(')[0];
        return { label: `if ${cond} …`, color: '#64748b', typeLabel: 'if' };
      }

      const parts = token.split(':');
      let si = 0;
      while (si < parts.length - 1 && STYLE_SET.has(parts[si])) si++;
      const base = parts.slice(si);
      const type = base[0] || '';
      const key = base.slice(1).join(':');

      // Separators — show the character
      if (type === 'sep') {
        const ch = SEP_CHARS[key] ?? key;
        return { label: ch || 'sep', color: TYPE_COLORS.sep, typeLabel: 'sep' };
      }

      // Nerd icons — show clean name
      if (type === 'nerd' || type === 'emoji') {
        let name = key;
        if (name.startsWith('nf-')) {
          const nfParts = name.slice(3).split(/[-_]/);
          name = nfParts.slice(1).join(' ') || nfParts[0];
        }
        return { label: `⬡ ${name}`, color: TYPE_COLORS.nerd, typeLabel: 'icon' };
      }

      // Text literals
      if (type === 'text') {
        return { label: `"${key}"`, color: TYPE_COLORS.text, typeLabel: 'text' };
      }

      // Regular type:key — show "type · key"
      const color = TYPE_COLORS[type] || '#a1a1aa';
      if (key) {
        return { label: `${type} · ${key}`, color, typeLabel: type };
      }
      return { label: type, color, typeLabel: type };
    }

    const X_SVG = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>';

    // --- Render chip builder ---
    function renderBuilder() {
      const existing = builder.querySelectorAll('.b-chip');
      existing.forEach(el => el.remove());
      builder.classList.remove('drop-end');

      builderEmpty.style.display = chips.length === 0 ? 'flex' : 'none';

      chips.forEach((chip, idx) => {
        const info = chipInfo(chip.token);
        const el = document.createElement('div');
        el.className = 'b-chip';
        el.draggable = true;
        el.dataset.idx = String(idx);
        el.dataset.id = chip.id;
        el.style.setProperty('--c', info.color);
        el.title = chip.token;
        el.innerHTML = `
          <span class="b-label">${escHtml(info.label)}</span>
          <button class="b-rm" aria-label="Remove">${X_SVG}</button>
        `;

        // Drag for reorder
        el.addEventListener('dragstart', (e) => {
          e.dataTransfer!.setData('application/x-reorder', String(idx));
          e.dataTransfer!.effectAllowed = 'move';
          el.classList.add('dragging');
          builder.classList.add('reordering');
        });
        el.addEventListener('dragend', () => {
          el.classList.remove('dragging');
          builder.classList.remove('reordering');
          clearDropIndicators();
        });

        // Remove
        el.querySelector('.b-rm')!.addEventListener('click', (e) => {
          e.stopPropagation();
          chips.splice(idx, 1);
          themeSelect.value = '__custom';
          renderBuilder();
          updatePreview();
        });

        builder.insertBefore(el, builderEmpty);
      });
    }

    function escHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // --- Drop indicators ---
    function clearDropIndicators() {
      builder.querySelectorAll('.b-chip').forEach(c => c.classList.remove('drop-before'));
      builder.classList.remove('drop-end');
    }

    function getDropIndex(e: DragEvent): number {
      const chipEls = Array.from(builder.querySelectorAll('.b-chip'));
      for (let i = 0; i < chipEls.length; i++) {
        const rect = chipEls[i].getBoundingClientRect();
        if (e.clientX < rect.left + rect.width / 2) return i;
      }
      return chipEls.length;
    }

    function showDropIndicator(idx: number) {
      clearDropIndicators();
      const chipEls = builder.querySelectorAll('.b-chip');
      if (idx < chipEls.length) {
        chipEls[idx].classList.add('drop-before');
      } else {
        builder.classList.add('drop-end');
      }
    }

    // --- Builder drag-and-drop ---
    builder.addEventListener('dragover', (e) => {
      e.preventDefault();
      const isReorder = e.dataTransfer!.types.includes('application/x-reorder');
      e.dataTransfer!.dropEffect = isReorder ? 'move' : 'copy';
      showDropIndicator(getDropIndex(e));
    });

    builder.addEventListener('dragleave', (e) => {
      if (!builder.contains(e.relatedTarget as Node)) clearDropIndicators();
    });

    builder.addEventListener('drop', (e) => {
      e.preventDefault();
      clearDropIndicators();
      builder.classList.remove('reordering');

      const reorderData = e.dataTransfer!.getData('application/x-reorder');
      const addData = e.dataTransfer!.getData('text/plain');
      const dropIdx = getDropIndex(e);

      if (reorderData) {
        const fromIdx = parseInt(reorderData, 10);
        if (fromIdx === dropIdx || fromIdx + 1 === dropIdx) return; // no-op
        const [moved] = chips.splice(fromIdx, 1);
        const insertAt = dropIdx > fromIdx ? dropIdx - 1 : dropIdx;
        chips.splice(insertAt, 0, moved);
      } else if (addData) {
        chips.splice(dropIdx, 0, { id: nextId(), token: addData });
      } else {
        return;
      }

      themeSelect.value = '__custom';
      renderBuilder();
      updatePreview();
    });

    // --- Sidebar segment palette ---
    const CATEGORIES = [
      { name: 'Claude', icon: 'sparkles', color: '#c084fc', items: ['claude:model', 'claude:model-id', 'claude:model-letter', 'claude:version', 'claude:effort', 'claude:effort-icon'] },
      { name: 'Context', icon: 'gauge', color: '#60a5fa', items: ['ctx:percent', 'ctx:remaining', 'ctx:tokens', 'ctx:bar', 'ctx:icon', 'ctx:in', 'ctx:out'] },
      { name: 'Cost', icon: 'dollar-sign', color: '#4ade80', items: ['cost:total', 'cost:total-cents', 'cost:duration', 'cost:lines', 'cost:lines-both', 'cost:added', 'cost:removed'] },
      { name: 'File System', icon: 'folder-open', color: '#fbbf24', items: ['fs:dir', 'fs:home', 'fs:project', 'fs:path', 'fs:relative'] },
      { name: 'Git', icon: 'git-branch', color: '#fb923c', items: ['git:branch', 'git:status', 'git:ahead-behind', 'git:dirty', 'git:staged', 'git:modified', 'git:untracked', 'git:commit', 'git:repo', 'git:repo-branch'] },
      { name: 'Environment', icon: 'terminal', color: '#22d3ee', items: ['env:node', 'env:node-short', 'env:python', 'env:user', 'env:hostname-short', 'env:os', 'env:arch'] },
      { name: 'Time', icon: 'clock', color: '#fb7185', items: ['time:now', 'time:12h', 'time:date', 'time:elapsed'] },
      { name: 'Usage', icon: 'activity', color: '#2dd4bf', items: ['usage:5h', 'usage:5h-bar:8', 'usage:5h-pace', 'usage:week', 'usage:week-bar:8', 'usage:week-pace'] },
      { name: 'Separators', icon: 'grip-horizontal', color: '#71717a', items: ['sep:pipe', 'sep:arrow', 'sep:dot', 'sep:dash', 'sep:slash', 'sep:chevron', 'sep:middot', 'sep:powerline', 'sep:newline'] },
      { name: 'Modifiers', icon: 'shapes', color: '#818cf8', items: ['nerd:folder', 'nerd:branch', 'nerd:star', 'nerd:rocket', 'nerd:clock', 'nerd:dollar', 'nerd:code', 'nerd:terminal'] },
    ];

    function buildSegmentPalette() {
      segCats.innerHTML = CATEGORIES.map(cat => `
        <div class="seg-group" style="--cat: ${cat.color}">
          <div class="seg-head">
            <i data-lucide="${cat.icon}"></i>
            <span>${cat.name}</span>
          </div>
          <div class="seg-chips">
            ${cat.items.map(item => {
              const info = chipInfo(item);
              return `<button class="chip" draggable="true" data-segment="${item}" title="${item}" style="--c: ${info.color}">
                <span class="chip-label">${escHtml(info.label)}</span>
              </button>`;
            }).join('')}
          </div>
        </div>
      `).join('');

      segCats.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('dragstart', (e) => {
          const el = chip as HTMLElement;
          (e as DragEvent).dataTransfer!.setData('text/plain', el.dataset.segment!);
          (e as DragEvent).dataTransfer!.effectAllowed = 'copy';
          el.classList.add('dragging');
        });
        chip.addEventListener('dragend', () => {
          (chip as HTMLElement).classList.remove('dragging');
          clearDropIndicators();
        });
        chip.addEventListener('click', () => {
          const seg = (chip as HTMLElement).dataset.segment!;
          chips.push({ id: nextId(), token: seg });
          themeSelect.value = '__custom';
          renderBuilder();
          updatePreview();
        });
      });

      createIcons({ icons: LUCIDE_ICONS });
    }

    // --- Load theme into chips ---
    function loadThemeChips(format: string) {
      const tokens = tokenize(format);
      chips = tokens.map(t => ({ id: nextId(), token: t }));
      renderBuilder();
    }

    function formatFromChips(): string {
      return chips.map(c => c.token).join(' ');
    }

    // --- Mock data & preview ---
    function buildMockData(): Partial<ClaudeInput> {
      const ctxPct = parseInt(ctxSlider.value);
      const selectedModel = modelSelect.selectedOptions[0];
      return {
        ...MOCK_DATA,
        model: {
          id: selectedModel.dataset.id || 'claude-sonnet-4-6',
          display_name: modelSelect.value,
          reasoning_effort: effortSelect.value,
        },
        workspace: {
          current_dir: '/Users/demo/projects/' + dirInput.value,
          project_dir: '/Users/demo/projects/' + dirInput.value,
        },
        cwd: '/Users/demo/projects/' + dirInput.value,
        cost: { ...MOCK_DATA.cost, total_cost_usd: parseFloat(costInput.value) || 0 },
        context_window: {
          ...MOCK_DATA.context_window,
          used_percentage: ctxPct,
          remaining_percentage: 100 - ctxPct,
        },
      };
    }

    (window as any).__mockBranch = 'main';
    (window as any).__mockGitClean = true;

    function updatePreview() {
      const format = formatFromChips();
      if (!format) {
        output.innerHTML = '<span class="empty">Add segments to see a preview</span>';
        installCmd.textContent = 'npx claudeline --install ""';
        return;
      }
      mockData = buildMockData();
      try {
        const html = renderToHtml(format, mockData);
        output.innerHTML = html || '<span class="empty">(empty output)</span>';
      } catch (e) {
        output.innerHTML = `<span class="error">Error: ${(e as Error).message}</span>`;
      }
      const currentTheme = themeSelect.value;
      if (currentTheme !== '__custom' && themes[currentTheme]) {
        installCmd.textContent = `npx claudeline --install --theme ${currentTheme}`;
      } else {
        installCmd.textContent = `npx claudeline --install "${format}"`;
      }
    }

    // --- Event listeners ---
    themeSelect.addEventListener('change', () => {
      const val = themeSelect.value;
      if (val !== '__custom' && themes[val]) {
        loadThemeChips(themes[val]);
      }
      updatePreview();
    });

    [modelSelect, effortSelect, gitStatusSelect].forEach(el =>
      el.addEventListener('change', updatePreview)
    );

    ctxSlider.addEventListener('input', () => {
      ctxValue.textContent = ctxSlider.value + '%';
      updatePreview();
    });

    [costInput, dirInput, branchInput].forEach(el =>
      el.addEventListener('input', updatePreview)
    );

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(installCmd.textContent || '');
      copyBtn.classList.add('copied');
      setTimeout(() => copyBtn.classList.remove('copied'), 1800);
    });

    // --- Init ---
    buildSegmentPalette();
    loadThemeChips(themes['default']);
    createIcons({ icons: LUCIDE_ICONS });
    updatePreview();
  </script>

  <style>
    :root {
      --bg: #09090b;
      --surface: #141418;
      --surface-2: #1e1e24;
      --surface-3: #27272e;
      --border: #2e2e38;
      --border-hover: #3f3f4a;
      --text: #fafafa;
      --text-2: #a1a1aa;
      --text-3: #71717a;
      --accent: #c084fc;
      --accent-dim: rgba(192, 132, 252, 0.12);
      --cyan: #22d3ee;

      --cl-black: #1a1a2e;
      --cl-red: #ff6b6b;
      --cl-green: #51cf66;
      --cl-yellow: #fcc419;
      --cl-blue: #74b9ff;
      --cl-magenta: #d97aff;
      --cl-cyan: #66d9ef;
      --cl-white: #e0e0e0;
      --cl-gray: #888;
      --cl-grey: #888;
      --cl-bright-red: #ff8787;
      --cl-bright-green: #69db7c;
      --cl-bright-yellow: #ffd43b;
      --cl-bright-blue: #91c9ff;
      --cl-bright-magenta: #e599ff;
      --cl-bright-cyan: #7ee8fc;
      --cl-bright-white: #fff;

      --sidebar-w: 260px;
      --radius: 10px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 10000;
      opacity: 0.018;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .anim {
      opacity: 0;
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: calc(var(--i, 0) * 0.09s + 0.05s);
    }

    @keyframes chipIn {
      from { opacity: 0; transform: scale(0.85); }
      to   { opacity: 1; transform: scale(1); }
    }

    /* ---- Layout ---- */
    .app { display: flex; min-height: 100vh; }

    /* ---- Sidebar ---- */
    .sidebar {
      width: var(--sidebar-w);
      flex-shrink: 0;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      z-index: 50;
      overflow: hidden;
    }

    .sidebar-header {
      padding: 1.1rem 0.9rem;
      border-bottom: 1px solid var(--border);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .brand-icon {
      width: 30px; height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), var(--cyan));
      color: #000;
    }
    .brand-icon svg { width: 15px; height: 15px; }

    .brand-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: -0.01em;
      background: linear-gradient(135deg, var(--accent), var(--cyan));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .brand-sub {
      font-size: 0.6rem;
      color: var(--text-3);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 500;
      margin-top: -1px;
    }

    .sidebar-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 0.5rem 0.6rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .sidebar-scroll::-webkit-scrollbar { width: 3px; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    .seg-group {
      padding: 0.45rem 0.5rem;
      border-radius: 8px;
      transition: background 0.15s;
    }
    .seg-group:hover { background: rgba(255,255,255,0.02); }

    .seg-head {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--cat);
      margin-bottom: 0.35rem;
      padding-left: 1px;
    }
    .seg-head svg { width: 12px; height: 12px; stroke-width: 2.5; }

    .seg-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    /* ---- Sidebar source chips ---- */
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 0;
      padding: 5px 11px;
      border-radius: 7px;
      background: color-mix(in srgb, var(--c) 10%, var(--surface-2));
      border: 1px solid color-mix(in srgb, var(--c) 12%, transparent);
      color: color-mix(in srgb, var(--c) 70%, var(--text));
      font-family: 'JetBrainsMono NF', 'SF Mono', monospace;
      font-size: 0.68rem;
      font-weight: 500;
      cursor: grab;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      user-select: none;
      line-height: 1.4;
    }

    .chip-dot { display: none; }

    .chip:hover {
      background: color-mix(in srgb, var(--c) 18%, var(--surface-2));
      border-color: color-mix(in srgb, var(--c) 30%, transparent);
      color: var(--text);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px color-mix(in srgb, var(--c) 15%, transparent),
                  0 0 0 1px color-mix(in srgb, var(--c) 15%, transparent);
    }
    .chip:active { transform: scale(0.96) translateY(0); cursor: grabbing; }
    .chip.dragging { opacity: 0.3; transform: scale(0.92); }

    .chip-label { pointer-events: none; }

    /* ---- Main ---- */
    main {
      flex: 1;
      margin-left: var(--sidebar-w);
      max-width: 820px;
      padding: 1.75rem 2.5rem 3rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .page-header { margin-bottom: -0.25rem; }
    .page-desc { font-size: 0.85rem; color: var(--text-3); }

    .section-label {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-3);
      margin-bottom: 0.5rem;
    }
    .section-label svg { width: 12px; height: 12px; }

    /* ---- Theme row ---- */
    .theme-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .theme-row label {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-3);
      display: flex;
      align-items: center;
      gap: 0.3rem;
      flex-shrink: 0;
    }
    .theme-row label svg { width: 12px; height: 12px; }

    select, input[type="text"], input[type="number"] {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 7px;
      color: var(--text);
      padding: 0.4rem 0.65rem;
      font-size: 0.8rem;
      font-family: 'Instrument Sans', sans-serif;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    select:focus, input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px var(--accent-dim);
    }
    input[type="range"] { accent-color: var(--accent); width: 100%; }

    /* ---- Chip builder ---- */
    .chip-builder {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      min-height: 56px;
      padding: 12px 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      align-items: center;
      align-content: flex-start;
      transition: border-color 0.2s, box-shadow 0.2s;
      position: relative;
    }

    .chip-builder:has(.b-chip:hover),
    .chip-builder.reordering {
      border-color: var(--border-hover);
      box-shadow: 0 0 0 1px var(--border-hover);
    }

    .chip-builder.drop-end {
      box-shadow: inset -3px 0 0 var(--accent);
    }

    .builder-empty {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.5rem 0;
      color: var(--text-3);
      font-size: 0.78rem;
      pointer-events: none;
    }
    .builder-empty svg { width: 16px; height: 16px; }

    /* ---- Builder chips ---- */
    .b-chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 8px 6px 12px;
      border-radius: 8px;
      background: color-mix(in srgb, var(--c) 14%, var(--surface-2));
      border: 1px solid color-mix(in srgb, var(--c) 18%, transparent);
      border-left: 3px solid var(--c);
      cursor: grab;
      user-select: none;
      transition: all 0.18s cubic-bezier(0.16, 1, 0.3, 1);
      animation: chipIn 0.2s ease;
      position: relative;
    }

    .b-chip:hover {
      background: color-mix(in srgb, var(--c) 20%, var(--surface-2));
      border-color: color-mix(in srgb, var(--c) 32%, transparent);
      border-left-color: var(--c);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px color-mix(in srgb, var(--c) 12%, transparent);
    }

    .b-chip:active { cursor: grabbing; }
    .b-chip.dragging { opacity: 0.2; transform: scale(0.9); }

    .b-chip.drop-before {
      margin-left: 16px;
    }
    .b-chip.drop-before::before {
      content: '';
      position: absolute;
      left: -11px;
      top: 3px;
      bottom: 3px;
      width: 3px;
      background: var(--accent);
      border-radius: 2px;
      box-shadow: 0 0 8px var(--accent);
    }

    .b-label {
      font-family: 'JetBrainsMono NF', 'SF Mono', monospace;
      font-size: 0.74rem;
      color: color-mix(in srgb, var(--c) 50%, var(--text));
      line-height: 1.3;
      white-space: nowrap;
      font-weight: 500;
    }

    .b-rm {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 18px; height: 18px;
      border-radius: 5px;
      background: transparent;
      border: none;
      color: var(--text-3);
      cursor: pointer;
      opacity: 0;
      transition: all 0.15s;
      flex-shrink: 0;
    }
    .b-chip:hover .b-rm { opacity: 0.5; }
    .b-rm:hover {
      opacity: 1 !important;
      background: rgba(255, 107, 107, 0.15);
      color: var(--cl-red);
    }

    /* ---- Terminal ---- */
    .terminal-glow {
      position: relative;
      border-radius: calc(var(--radius) + 2px);
    }
    .terminal-glow::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      padding: 1px;
      background: linear-gradient(135deg, rgba(192,132,252,0.35), rgba(34,211,238,0.12) 50%, rgba(192,132,252,0.15));
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }

    .terminal {
      background: #0a0a12;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: 0 4px 32px rgba(0,0,0,0.4), 0 0 80px -24px rgba(168,85,247,0.1);
    }

    .terminal-chrome {
      display: flex;
      align-items: center;
      padding: 10px 14px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
    }

    .terminal-dots { display: flex; gap: 6px; }
    .terminal-dots span { width: 10px; height: 10px; border-radius: 50%; }
    .terminal-dots span:nth-child(1) { background: #ff5f57; }
    .terminal-dots span:nth-child(2) { background: #febc2e; }
    .terminal-dots span:nth-child(3) { background: #28c840; }

    .terminal-title {
      flex: 1;
      text-align: center;
      font-size: 0.72rem;
      color: var(--text-3);
      font-weight: 500;
    }

    .terminal-body {
      padding: 1rem 1.25rem;
      font-family: 'JetBrainsMono NF', 'SF Mono', monospace;
      font-size: 0.88rem;
      line-height: 1.6;
      min-height: 80px;
    }

    .prompt-line {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      color: var(--text-3);
    }
    .prompt-char { color: var(--cl-green); }

    .cursor {
      display: inline-block;
      width: 8px; height: 1.1em;
      background: var(--text);
      opacity: 0.6;
      animation: blink 1s step-end infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }

    .statusline {
      padding: 6px 0;
      font-family: 'JetBrainsMono NF', 'SF Mono', monospace;
      font-size: 0.88rem;
      line-height: 1.8;
      word-break: break-all;
    }
    .statusline .empty { color: var(--text-3); font-style: italic; }
    .statusline .error { color: var(--cl-red); }

    /* ANSI classes */
    .cl-red { color: var(--cl-red); }
    .cl-green { color: var(--cl-green); }
    .cl-yellow { color: var(--cl-yellow); }
    .cl-blue { color: var(--cl-blue); }
    .cl-magenta { color: var(--cl-magenta); }
    .cl-cyan { color: var(--cl-cyan); }
    .cl-white { color: var(--cl-white); }
    .cl-gray, .cl-grey { color: var(--cl-gray); }
    .cl-black { color: var(--cl-black); }
    .cl-bright-red { color: var(--cl-bright-red); }
    .cl-bright-green { color: var(--cl-bright-green); }
    .cl-bright-yellow { color: var(--cl-bright-yellow); }
    .cl-bright-blue { color: var(--cl-bright-blue); }
    .cl-bright-magenta { color: var(--cl-bright-magenta); }
    .cl-bright-cyan { color: var(--cl-bright-cyan); }
    .cl-bright-white { color: var(--cl-bright-white); }
    .cl-bold { font-weight: 700; }
    .cl-dim { opacity: 0.6; }
    .cl-italic { font-style: italic; }
    .cl-underline { text-decoration: underline; }
    .cl-strikethrough { text-decoration: line-through; }
    .cl-bg-red { background: var(--cl-red); color: #000; padding: 0 2px; border-radius: 2px; }
    .cl-bg-green { background: var(--cl-green); color: #000; padding: 0 2px; border-radius: 2px; }
    .cl-bg-blue { background: var(--cl-blue); color: #000; padding: 0 2px; border-radius: 2px; }
    .cl-bg-yellow { background: var(--cl-yellow); color: #000; padding: 0 2px; border-radius: 2px; }
    .cl-bg-magenta { background: var(--cl-magenta); color: #000; padding: 0 2px; border-radius: 2px; }
    .cl-bg-cyan { background: var(--cl-cyan); color: #000; padding: 0 2px; border-radius: 2px; }
    .cl-bg-white { background: var(--cl-white); color: #000; padding: 0 2px; border-radius: 2px; }
    .cl-bg-black { background: var(--cl-black); padding: 0 2px; border-radius: 2px; }

    /* ---- Install ---- */
    .install-card {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.6rem 0.8rem;
    }
    .install-card code {
      flex: 1;
      font-family: 'JetBrainsMono NF', 'SF Mono', monospace;
      font-size: 0.78rem;
      color: var(--cl-green);
      white-space: nowrap;
      overflow-x: auto;
    }
    .install-card button {
      position: relative;
      background: var(--surface-2);
      border: 1px solid var(--border);
      color: var(--text-2);
      width: 30px; height: 30px;
      border-radius: 7px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.15s;
    }
    .install-card button svg { width: 14px; height: 14px; }
    .install-card button:hover { border-color: var(--accent); color: var(--accent); }
    .install-card button .copy-default,
    .install-card button .copy-done {
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.15s;
    }
    .install-card button .copy-done {
      position: absolute;
      opacity: 0;
      color: var(--cl-green);
    }
    .install-card button.copied .copy-default { opacity: 0; }
    .install-card button.copied .copy-done { opacity: 1; }

    /* ---- FAB ---- */
    #fab {
      position: fixed;
      bottom: 1.25rem; right: 1.25rem;
      width: 42px; height: 42px;
      border-radius: 12px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      color: var(--text-2);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      z-index: 100;
    }
    #fab svg { width: 17px; height: 17px; }
    #fab:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--surface-3);
      transform: rotate(30deg);
      box-shadow: 0 4px 20px rgba(192,132,252,0.15);
    }

    /* ---- Sheet ---- */
    .sheet-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(4px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s;
      z-index: 200;
    }
    .sheet-overlay.open { opacity: 1; pointer-events: auto; }

    .sheet {
      position: fixed;
      bottom: 0; right: 0;
      width: 380px;
      max-width: 100vw;
      max-height: 80vh;
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
      border-radius: 14px 0 0 0;
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 300;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .sheet.open { transform: translateY(0); }

    .sheet-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.8rem 1rem;
      border-bottom: 1px solid var(--border);
    }
    .sheet-head h3 {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .sheet-head h3 svg { width: 14px; height: 14px; color: var(--text-3); }

    .sheet-close {
      background: none;
      border: none;
      color: var(--text-3);
      cursor: pointer;
      padding: 4px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s;
    }
    .sheet-close svg { width: 15px; height: 15px; }
    .sheet-close:hover { color: var(--text); background: var(--surface-2); }

    .sheet-body {
      padding: 0.8rem 1rem;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
    }

    .sheet-body label {
      font-size: 0.62rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-3);
    }

    .sheet-row { display: flex; gap: 0.6rem; }
    .sheet-field { display: flex; flex-direction: column; gap: 0.2rem; flex: 1; }

    .slider-row { display: flex; align-items: center; gap: 0.5rem; }
    .slider-row input[type="range"] { flex: 1; }
    .slider-val {
      font-size: 0.72rem;
      color: var(--cyan);
      font-family: 'JetBrainsMono NF', monospace;
      min-width: 2.5em;
      text-align: right;
    }

    /* ---- Responsive ---- */
    @media (max-width: 900px) {
      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 4px 0 24px rgba(0,0,0,0.4);
      }
      .sidebar.open { transform: translateX(0); }
      main { margin-left: 0; padding: 1.75rem 1.5rem; }
    }

    @media (max-width: 600px) {
      .sheet { width: 100vw; border-radius: 14px 14px 0 0; border-left: none; }
      .sheet-row { flex-direction: column; }
      main { padding: 1.5rem 1rem; }
    }
  </style>
</Layout>
